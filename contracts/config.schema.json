{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/bytechainx/postgresx/contracts/config.schema.json",
  "title": "Postgresx Config",
  "type": "object",
  "additionalProperties": false,
  "required": ["host", "port", "database", "user", "password", "sslmode"],
  "properties": {
    "host": {
      "type": "string",
      "minLength": 1
    },
    "port": {
      "type": "integer",
      "minimum": 1,
      "maximum": 65535
    },
    "database": {
      "type": "string",
      "minLength": 1
    },
    "user": {
      "type": "string",
      "minLength": 1
    },
    "password": {
      "type": "string",
      "minLength": 1,
      "x-secret": true
    },
    "sslmode": {
      "type": "string",
      "minLength": 1
    },
    "max_open_conns": {
      "type": "integer",
      "minimum": 0
    },
    "min_idle_conns": {
      "type": "integer",
      "minimum": 0
    },
    "max_conn_lifetime_ms": {
      "type": "integer",
      "minimum": 0
    },
    "max_conn_idle_time_ms": {
      "type": "integer",
      "minimum": 0
    },
    "connect_timeout_ms": {
      "type": "integer",
      "minimum": 0
    },
    "health_timeout_ms": {
      "type": "integer",
      "minimum": 0
    },
    "application_name": {
      "type": "string"
    }
  }
}
