# ============================================================
# postgresx 环境变量模板
# 复制为 .env 后填入实际值（.env 已在 .gitignore 中排除）
#
# PostgreSQL L2 adapter — 连接信息由环境变量注入
# ============================================================

# ---- 集成测试 ----
# 真实 PostgreSQL 集成测试 DSN（优先级高于 POSTGRES_TEST_DSN）
POSTGRESX_INTEGRATION_DSN=
# 备选测试 DSN
POSTGRES_TEST_DSN=

# ---- 示例程序 ----
# 设为 1 启用 live 模式示例（连接真实 PostgreSQL）
POSTGRESX_EXAMPLE_LIVE=0

# ---- PostgreSQL 连接参数（示例程序使用）----
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=
PGDATABASE=postgres
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
